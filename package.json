{
  "name": "hum",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "firebase:login": "mkdir -p \"$HOME/.config-humm-firebase\" && CI=1 XDG_CONFIG_HOME=\"$HOME/.config-humm-firebase\" npx firebase login",
    "deploy:indexes": "mkdir -p \"$HOME/.config-humm-firebase\" && CI=1 XDG_CONFIG_HOME=\"$HOME/.config-humm-firebase\" npx firebase deploy --only firestore:indexes",
    "migrate:auth-email": "node scripts/migrate-auth-email.mjs",
    "reset:couple-data": "node scripts/reset-couple-data.mjs",
    "seed:starter-nominations": "node scripts/seed-starter-nominations.mjs",
    "recompute:gamification": "tsx scripts/recompute-gamification.ts",
    "eas:login": "npx eas-cli login",
    "eas:init": "npx eas-cli init",
    "eas:env:push:preview": "npx eas-cli env:push preview --path .env",
    "eas:env:push:production": "npx eas-cli env:push production --path .env",
    "eas:env:list": "npx eas-cli env:list preview",
    "build:android:apk": "npx eas-cli build -p android --profile preview",
    "build:android:play": "npx eas-cli build -p android --profile production",
    "verify:store-pages": "playwright test tests/store-pages.spec.ts",
    "demo:create": "node scripts/create-demo-accounts.mjs --confirm CREATE-DEMO",
    "demo:create:force": "node scripts/create-demo-accounts.mjs --confirm CREATE-DEMO --force",
    "demo:seed-moods": "node scripts/seed-demo-moods.mjs --confirm SEED-MOODS",
    "demo:seed-moods:force": "node scripts/seed-demo-moods.mjs --confirm SEED-MOODS --force",
    "demo:seed-habits": "node scripts/seed-demo-habits.mjs --confirm SEED-HABITS"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@types/react": "~19.1.10",
    "expo": "~54.0.34",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.11.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "zustand": "^5.0.12"
  },
  "reanimated": {
    "staticFeatureFlags": {
      "ANDROID_SYNCHRONOUSLY_UPDATE_UI_PROPS": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@expo/ngrok": "^4.1.3",
    "@playwright/test": "^1.51.0",
    "firebase-admin": "^13.0.2",
    "firebase-tools": "^14.0.0",
    "tsx": "^4.19.3"
  }
}
