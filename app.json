{
  "expo": {
    "name": "Hum - rituals",
    "slug": "humm",
    "version": "1.0.0",
    "scheme": "humtum",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#131118",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#131118"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.humtum.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#131118"
      },
      "package": "com.humtum.app",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Hum uses your photos for nominations and reasons."
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "30c5357d-ddd0-490b-a158-fd22c872392e"
      }
    }
  }
}
